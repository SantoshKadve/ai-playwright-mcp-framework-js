{
  "name": "ai-playwright-mcp-framework-js",
  "version": "1.0.0",
  "description": "AI-driven automation framework with Playwright + JavaScript + MCP-ready architecture for UI and API testing",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test tests/ui",
    "test:api": "playwright test tests/api",
    "test:e2e": "playwright test tests/e2e",
    "test:contract": "playwright test tests/contract",
    "test:smoke": "playwright test --grep @smoke",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "report:allure": "allure generate allure-results --clean -o allure-report",
    "report:allure:serve": "allure open allure-report",
    "report:allure:clean": "rm -rf allure-results allure-report",
    "mcp:demo": "node scripts/mcp-demo.js",
    "mcp:inspector": "node scripts/mcp-inspector-config.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "allure-playwright": "^3.6.0",
    "dotenv": "^16.4.5"
  }
}
